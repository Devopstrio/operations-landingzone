# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="Operations Landing Zone"

# Security
SECRET_KEY=opslandingzonesupersecret123
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ops_landingzone_db

# Redis / Queue
REDIS_HOST=localhost
REDIS_PORT=6379

# Integrations
PAGERDUTY_API_KEY=your-pd-key
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
JIRA_API_TOKEN=your-jira-token

# Operations Automation
AUTO_RESOLVE_ENABLED=true
INCIDENT_ESCALATION_TIMEOUT_MINS=15
RUNBOOK_EXECUTION_TIMEOUT_SECS=300

# Grafana Dashboard
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_PASSWORD=admin
